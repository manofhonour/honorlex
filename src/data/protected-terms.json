  "patterns": [
    { "id": "citation-parenthetical", "label": "Citation", "source": "\\([A-Z][\\p{L}'’.-]+(?:\\s+et\\s+al\\.)?(?:\\s*(?:&|and)\\s*[A-Z][\\p{L}'’.-]+)?(?:,\\s*\\d{4}[a-z]?)?(?:,\\s*p+\\.\\s*\\d+)?\\)" },
    { "id": "citation-narrative", "label": "Narrative citation", "source": "\\b[A-Z][\\p{L}'’.-]+(?:\\s+et\\s+al\\.)?\\s*\\(\\d{4}[a-z]?\\)" },
    { "id": "doi", "label": "DOI", "source": "\\b(?:doi:\\s*)?10\\.\\d{4,9}/[-._;()/:A-Z0-9]+\\b" },
    { "id": "url", "label": "URL", "source": "\\bhttps?://[^\\s)]+|\\bwww\\.[^\\s)]+" },
    { "id": "reference-list-line", "label": "Reference list line", "source": "(?:^|\\n)\\s*[A-Z][\\p{L}'’.-]+,\\s*(?:[A-Z]\\.)+(?:,\\s*&\\s*[A-Z][\\p{L}'’.-]+,\\s*(?:[A-Z]\\.)+)?\\s*\\(\\d{4}[a-z]?\\)\\..*(?=\\n|$)" },
    { "id": "year", "label": "Year", "source": "\\b(?:19|20)\\d{2}[a-z]?\\b" },
    { "id": "number", "label": "Number", "source": "\\b\\d+(?:[.,]\\d+)?%?\\b|(?<!\\w)\\.\\d+\\b" },
    { "id": "p-value", "label": "p value", "source": "\\bp\\s*[<=>]\\s*\\.?\\d+\\b" },
    { "id": "t-test", "label": "t statistic", "source": "\\bt\\s*\\(\\s*\\d+\\s*\\)\\s*=\\s*-?\\d+(?:\\.\\d+)?" },
    { "id": "chi-square", "label": "chi-square statistic", "source": "(?:χ²|χ2|chi-square)\\s*\\([^)]*\\)(?:\\s*=\\s*-?\\d+(?:\\.\\d+)?)?" },
    { "id": "f-statistic", "label": "F statistic", "source": "\\bF\\s*\\(\\s*\\d+\\s*,\\s*\\d+\\s*\\)\\s*=\\s*-?\\d+(?:\\.\\d+)?" },
    { "id": "r-statistic", "label": "r statistic", "source": "\\br\\s*=\\s*-?\\.?\\d+" },
    { "id": "descriptive-statistic", "label": "Descriptive statistic", "source": "\\b(?:SD|M|N|n)\\s*=\\s*-?\\d+(?:\\.\\d+)?" },
    { "id": "alpha-statistic", "label": "Alpha statistic", "source": "(?:α|alpha)\\s*=\\s*\\.?\\d+" },
    { "id": "confidence-interval", "label": "Confidence interval", "source": "\\b\\d{1,3}%\\s*CI\\b(?:\\s*\\[[^\\]]+\\])?" },
    { "id": "quoted-text-double", "label": "Quotation", "source": "\"[^\"]+\"|“[^”]+”" },
    { "id": "quoted-text-single", "label": "Quotation", "source": "'[^']+'|‘[^’]+’" },
    { "id": "quote-marker-line", "label": "Quoted participant statement", "source": "(?:^|\\n)\\s*(?:>|Quote:|Quotation:|Participant\\s+\\d+:|Interviewee\\s+\\d+:|P\\d+:|ST\\d+:|HT\\d+:|T\\d+:|S\\d+:)\\s+.*(?=\\n|$)" },
    { "id": "participant-code", "label": "Participant code", "source": "\\b(?:ST|HT|T|P|S)\\d{1,3}\\b|\\b(?:Interviewee|Participant)\\s+\\d{1,3}\\b" },
    { "id": "ethics-approval", "label": "Ethics approval", "source": "\\b(?:Ethics|IRB|Approval|Protocol|Ethics committee|approval number)\\s*(?:No\\.?|Number|ID)?\\s*[:#-]?\\s*[A-Z0-9/-]{3,}\\b" },
    { "id": "institution-name", "label": "Institution name", "source": "\\b[A-ZÇĞİÖŞÜ][\\p{L}&'’.-]+(?:\\s+[A-ZÇĞİÖŞÜ][\\p{L}&'’.-]+)*\\s+(?:University|School|Institute|Ministry|Department|Faculty)\\b" }
  ]
}
